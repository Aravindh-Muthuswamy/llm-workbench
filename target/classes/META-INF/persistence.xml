<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.2" xmlns="https://jakarta.ee/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence           http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd">
  <persistence-unit name="vanigam" transaction-type="RESOURCE_LOCAL">
    <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
    <class>com.infomatrices.vanigam.contacts.model.Contact</class>
    <class>com.infomatrices.vanigam.inventory.brand.Brand</class>
    <class>com.infomatrices.vanigam.country.model.Country</class>
    <class>com.infomatrices.vanigam.state.model.State</class>
    <class>com.infomatrices.vanigam.currency.model.Currency</class>
    <class>com.infomatrices.vanigam.inventory.category.Category</class>
    <class>com.infomatrices.vanigam.inventory.subcategory.SubCategory</class>
    <class>com.infomatrices.vanigam.inventory.model.Inventory</class>
    <class>com.infomatrices.vanigam.users.model.AppUser</class>
    <class>com.infomatrices.vanigam.users.model.AppUserRole</class>
    <class>com.infomatrices.vanigam.sales.Sales</class>
    <class>com.infomatrices.vanigam.sales.DeliveryChallan</class>
    <class>com.infomatrices.vanigam.sales.DeliveryChallanItems</class>
    <class>com.infomatrices.vanigam.sales.SalesContact</class>
    <class>com.infomatrices.vanigam.sales.SalesItems</class>
    <class>com.infomatrices.vanigam.sales.SalesPayment</class>
    <class>com.infomatrices.vanigam.inventory.stock.model.Stock</class>
    <class>com.infomatrices.vanigam.stockbill.StockNote</class>
    <class>com.infomatrices.vanigam.stockbill.StockNoteItems</class>
    <validation-mode>NONE</validation-mode>
    <properties>
      <property name="hibernate.connection.url" value="jdbc:sqlite:vanigam.db"/>
      <property name="hibernate.connection.username" value=""/>
      <property name="hibernate.connection.driver_class" value="org.sqlite.JDBC"/>
      <property name="hibernate.connection.password" value=""/>
      <property name="hibernate.dialect" value="org.hibernate.community.dialect.SQLiteDialect"/>
      <property name="hibernate.show_sql" value="true"/>
    </properties>
  </persistence-unit>
</persistence>
